### --- Java / Maven --- ###
target/
*.jar
*.war
*.ear
!.mvn/wrapper/maven-wrapper.jar

### --- IntelliJ IDEA --- ###
.idea/
*.iws
*.iml
*.ipr
out/
# Uncomment the line below if you want to share IntelliJ run configurations with the team
# !.idea/runConfigurations/

### --- Visual Studio Code --- ###
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

### --- Node / TypeScript --- ###
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# Compiled frontend assets (Maven re-generates these from TS)
src/main/resources/static/js/
*.js.map

### --- Docker & Local Data --- ###
# Ignore local database storage
postgres-data/
# Ignore the local Maven dependency cache (Prevents massive Git commits)
.m2-cache/
# Dev Container local settings
.devcontainer/local-settings.json

### --- System & Logs --- ###
*.log
.DS_Store
Thumbs.db
